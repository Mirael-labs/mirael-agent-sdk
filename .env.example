# ╔══════════════════════════════════════════════════════════════════╗
# ║  Mirael Agent SDK — Environment Configuration                    ║
# ║  Copy this file to .env and fill in the required values          ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# 🔴 REQUIRED   — bot won't start without these
# 🟡 OPTIONAL   — has a sensible default, change only if needed
# ⚪ CHANNEL    — only needed if using that channel (Discord/Telegram)

# ─── LLM ─────────────────────────────────────────────────────────────────────
# 🔴 REQUIRED — get from console.anthropic.com → API Keys
MIRAEL_ANTHROPIC_API_KEY=

# 🟡 OPTIONAL — model to use (default is claude-sonnet-4-5)
MIRAEL_LLM_MODEL=claude-sonnet-4-5
MIRAEL_LLM_MAX_TOKENS=4096

# ─── Embeddings ──────────────────────────────────────────────────────────────
# 🟡 OPTIONAL — default is "local" (free, no API key needed)
#              set to "openai" only if you want text-embedding-3-large
MIRAEL_EMBEDDING_PROVIDER=local

# 🟡 OPTIONAL — local model downloaded automatically on first run (~1.3 GB)
MIRAEL_LOCAL_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ⚪ ONLY if MIRAEL_EMBEDDING_PROVIDER=openai — get from platform.openai.com
MIRAEL_OPENAI_API_KEY=

MIRAEL_EMBEDDING_MODEL=text-embedding-3-large

# ─── Vector Store ─────────────────────────────────────────────────────────────
# 🔴 REQUIRED — Qdrant URL. Use cloud.qdrant.io (free) or http://localhost:6333
MIRAEL_QDRANT_URL=http://localhost:6333

# 🟡 OPTIONAL — leave blank for local Qdrant, required for Qdrant Cloud
MIRAEL_QDRANT_API_KEY=

# 🟡 OPTIONAL — collection name for stored docs
MIRAEL_QDRANT_COLLECTION=mirael_docs

# ─── Hyperliquid ─────────────────────────────────────────────────────────────
# 🟡 OPTIONAL — "mainnet" or "testnet"
MIRAEL_HL_NETWORK=mainnet

# 🟡 OPTIONAL — default wallet for demos (users can pass wallet per command)
MIRAEL_HL_WALLET_ADDRESS=

# ─── Arbitrum / Aave / GMX ───────────────────────────────────────────────────
# 🟡 OPTIONAL — public Arbitrum RPC (free). Use Alchemy for production reliability
MIRAEL_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# 🟡 OPTIONAL — wallet for Aave/GMX queries (can also pass per command)
MIRAEL_EVM_WALLET_ADDRESS=

# ─── App ─────────────────────────────────────────────────────────────────────
# 🟡 OPTIONAL — log level: DEBUG | INFO | WARNING | ERROR
MIRAEL_LOG_LEVEL=INFO

# 🟡 OPTIONAL — environment: development | staging | production
MIRAEL_ENVIRONMENT=development

# ─── Discord ──────────────────────────────────────────────────────────────────
# ⚪ ONLY for Discord bot — discord.com/developers/applications → Bot → Token
MIRAEL_DISCORD_BOT_TOKEN=

# ⚪ OPTIONAL — restrict slash commands to one server (faster sync in dev)
#   Find it: Discord → Server Settings → Widget → Server ID
# MIRAEL_DISCORD_GUILD_ID=123456789

# ─── Telegram ────────────────────────────────────────────────────────────────
# ⚪ ONLY for Telegram bot — message @BotFather → /newbot
MIRAEL_TELEGRAM_BOT_TOKEN=
