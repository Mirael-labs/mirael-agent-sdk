# ─── LLM ─────────────────────────────────────────────────────────────────────
# Required: Anthropic API key for claude-sonnet-4-5
MIRAEL_ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model
MIRAEL_LLM_MODEL=claude-sonnet-4-5

# Optional: max tokens per completion
MIRAEL_LLM_MAX_TOKENS=4096

# ─── Embeddings ──────────────────────────────────────────────────────────────
# Embedding backend: 'local' (default, no API key needed) or 'openai'
MIRAEL_EMBEDDING_PROVIDER=local

# Local model (used when MIRAEL_EMBEDDING_PROVIDER=local)
# Downloaded automatically on first use (~1.3 GB from Hugging Face)
MIRAEL_LOCAL_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# OpenAI key — only needed if MIRAEL_EMBEDDING_PROVIDER=openai
MIRAEL_OPENAI_API_KEY=

MIRAEL_EMBEDDING_MODEL=text-embedding-3-large

# ─── Vector Store ─────────────────────────────────────────────────────────────
# Required: Qdrant URL (local default shown)
MIRAEL_QDRANT_URL=http://localhost:6333

# Optional: Qdrant Cloud API key (leave blank for local)
MIRAEL_QDRANT_API_KEY=

# Optional: collection name
MIRAEL_QDRANT_COLLECTION=mirael_docs

# ─── Hyperliquid ─────────────────────────────────────────────────────────────
# Optional: target network
MIRAEL_HL_NETWORK=mainnet

# Optional: default wallet address for on-chain queries
MIRAEL_HL_WALLET_ADDRESS=0x...

# ─── Arbitrum / Aave ─────────────────────────────────────────────────────────
# Arbitrum JSON-RPC URL (default: public endpoint, use Alchemy for reliability)
MIRAEL_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Optional: wallet address for EVM on-chain queries
MIRAEL_EVM_WALLET_ADDRESS=0x...

# ─── App ─────────────────────────────────────────────────────────────────────
# Optional: log level (DEBUG | INFO | WARNING | ERROR)
MIRAEL_LOG_LEVEL=INFO

# Optional: environment (development | staging | production)
MIRAEL_ENVIRONMENT=development

# ─── Discord ──────────────────────────────────────────────────────────────────
# Get from: https://discord.com/developers/applications → Bot → Token
MIRAEL_DISCORD_BOT_TOKEN=

# Optional: restrict slash commands to one server (faster sync during dev)
# Find it: Discord → Server Settings → Widget → Server ID
MIRAEL_DISCORD_GUILD_ID=

# ─── Telegram ────────────────────────────────────────────────────────────────
# Get from: @BotFather on Telegram → /newbot
MIRAEL_TELEGRAM_BOT_TOKEN=
