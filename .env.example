# ─── LLM ─────────────────────────────────────────────────────────────────────
# Required: Anthropic API key for claude-sonnet-4-5
MIRAEL_ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default model
MIRAEL_LLM_MODEL=claude-sonnet-4-5

# Optional: max tokens per completion
MIRAEL_LLM_MAX_TOKENS=4096

# ─── Embeddings ──────────────────────────────────────────────────────────────
# Required: OpenAI API key for text-embedding-3-large
MIRAEL_OPENAI_API_KEY=sk-...

# Optional: embedding model
MIRAEL_EMBEDDING_MODEL=text-embedding-3-large

# ─── Vector Store ─────────────────────────────────────────────────────────────
# Required: Qdrant URL (local default shown)
MIRAEL_QDRANT_URL=http://localhost:6333

# Optional: Qdrant Cloud API key (leave blank for local)
MIRAEL_QDRANT_API_KEY=

# Optional: collection name
MIRAEL_QDRANT_COLLECTION=mirael_docs

# ─── Hyperliquid ─────────────────────────────────────────────────────────────
# Optional: target network
MIRAEL_HL_NETWORK=mainnet

# Optional: default wallet address for on-chain queries
MIRAEL_HL_WALLET_ADDRESS=0x...

# ─── App ─────────────────────────────────────────────────────────────────────
# Optional: log level (DEBUG | INFO | WARNING | ERROR)
MIRAEL_LOG_LEVEL=INFO

# Optional: environment (development | staging | production)
MIRAEL_ENVIRONMENT=development
